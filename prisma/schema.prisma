// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js models (Prisma adapter) ---

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  avatarId      Int?
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)

  accounts    Account[]
  sessions    Session[]
  predictions Prediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

model Match {
  id               String      @id @default(cuid())
  externalId       Int?        @unique // football-data.org match id
  stage            String // e.g. "GROUP_STAGE", "ROUND_OF_16", "FINAL"
  group            String? // e.g. "Group A"
  matchday         Int?
  kickoff          DateTime
  homeTeam         String
  awayTeam         String
  homeTeamCrestUrl String?
  awayTeamCrestUrl String?
  homeScore        Int? // regulation/extra-time score, excludes penalties
  awayScore        Int?
  homePenalties    Int? // set only when the match was decided by a penalty shootout
  awayPenalties    Int?
  status           MatchStatus @default(SCHEDULED)

  predictions Prediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kickoff])
  @@index([status])
}

model GroupStanding {
  id             String  @id @default(cuid())
  group          String // e.g. "Group A"
  position       Int
  teamName       String
  teamCrestUrl   String?
  playedGames    Int
  won            Int
  drawn          Int
  lost           Int
  goalsFor       Int
  goalsAgainst   Int
  goalDifference Int
  points         Int

  updatedAt DateTime @updatedAt

  @@unique([group, teamName])
  @@index([group, position])
}

enum BetType {
  HOME_WIN
  AWAY_WIN
  DRAW
  EXACT_SCORE
}

model Prediction {
  id       String  @id @default(cuid())
  userId   String
  matchId  String
  betType  BetType
  homeScore Int? // only set when betType == EXACT_SCORE
  awayScore Int? // only set when betType == EXACT_SCORE
  points   Int? // null until match is FINISHED and scoring has run

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
}
